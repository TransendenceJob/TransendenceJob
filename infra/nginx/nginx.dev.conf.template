server {
    listen ${NGINX_INTERNAL_PORT};
    server_name _;

    resolver 127.0.0.11 valid=30s;

    client_max_body_size 20m;

    # Disable caching in development
    add_header Cache-Control "no-store";

    # -------------------------------
    # Frontend (Next.js dev server)
    # -------------------------------
    location / {
        proxy_pass http://frontend:${FRONTEND_INTERNAL_PORT};

        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Next.js hot reload websocket
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_cache_bypass $http_upgrade;
    }

    # -------------------------------
    # NextAuth → Frontend
    # -------------------------------
    location /api/auth/ {
        proxy_pass http://frontend:${FRONTEND_INTERNAL_PORT};

        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # -------------------------------
    # Public API → BFF
    # -------------------------------
    location /api/ {
        proxy_pass http://bff:${BFF_INTERNAL_PORT}/;

        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # -------------------------------
    # Game WebSocket
    # -------------------------------
    location /socket.io/ {
        proxy_pass http://game_service:${GAME_INTERNAL_PORT};

        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # -------------------------------
    # Generated map assets
    # -------------------------------
    location /assets/maps/ {
        alias /usr/share/nginx/html/maps/;

        access_log off;

        add_header Cache-Control "no-store";

        try_files $uri =404;
    }

    # -------------------------------
    # Health check endpoint
    # -------------------------------
    location /health {
        return 200 'ok';
        add_header Content-Type text/plain;
    }
}