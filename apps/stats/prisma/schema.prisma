// audit tabel for tracing what is heppening inside the audit
model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  requestId  String?
  actorId    String? // user id or service id
  action     String // e.g. "update_player_stats"
  entityType String // e.g. "Player", "Match"
  entityId   String? // e.g. "player:123"
  before     Json?
  after      Json?
  source     String // "stats_service"
}

model PlayerStats {
  id                String             @id @default(uuid())
  userId            String             @unique
  matchesWon        Match[]            @relation("Winner")
  matchesLost       Match[]            @relation("Loser")
  achievements      Achievement[]
  weapons           WeaponUsage[]
  xp                Int                @default(0)
  level             Int                @default(1)
  wins              Int                @default(0)
  losses            Int                @default(0)
  kills             Int                @default(0)
  deaths            Int                @default(0)
  damageDealt       Int                @default(0)
  damageTaken       Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  matchParticipants MatchParticipant[]
}

model Match {
  id                String             @id @default(uuid())
  winnerId          String
  loserId           String
  winner            PlayerStats        @relation("Winner", fields: [winnerId], references: [userId])
  loser             PlayerStats        @relation("Loser", fields: [loserId], references: [userId])
  duration          Int
  createdAt         DateTime           @default(now())
  matchParticipants MatchParticipant[]
}

model Achievement {
  id        String      @id @default(uuid())
  userId    String
  user      PlayerStats @relation(fields: [userId], references: [userId])
  type      String
  createdAt DateTime    @default(now())
}

model WeaponUsage {
  id         String      @id @default(uuid())
  userId     String
  user       PlayerStats @relation(fields: [userId], references: [userId])
  weapon     String
  shotsFired Int         @default(0)
  hits       Int         @default(0)
  kills      Int         @default(0)
  damage     Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model MatchParticipant {
  id       String      @id @default(uuid())
  matchId  String
  userId   String
  match    Match       @relation(fields: [matchId], references: [id])
  user     PlayerStats @relation(fields: [userId], references: [userId])
  isWinner Boolean
}

/**
 * ┌────────────────────┐
 * │    PlayerStats     │
 * │--------------------│
 * │ userId (unique)    │
 * │ xp, level, ...     │
 * └────────┬───────────┘
 * │
 * ┌───────────────┼───────────────┐
 * │               │               │
 * │               │               │
 * ▼               ▼               ▼
 * ┌────────────────┐  ┌────────────────┐  ┌────────────────┐
 * │  Achievement   │  │  WeaponUsage   │  │ MatchParticipant│
 * │----------------│  │----------------│  │----------------│
 * │ userId (FK)    │  │ userId (FK)    │  │ userId (FK)    │
 * │ type           │  │ weapon         │  │ matchId (FK)   │
 * └────────────────┘  └────────────────┘  │ isWinner       │
 * └──────┬─────────┘
 * │
 * ▼
 * ┌────────────────┐
 * │     Match      │
 * │----------------│
 * │ id             │
 * │ duration       │
 * └────────────────┘
 */
