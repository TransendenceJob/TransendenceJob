generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PlayerStats {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  xp          Int      @default(0)
  level       Int      @default(1)
  wins        Int      @default(0)
  losses      Int      @default(0)
  kills       Int      @default(0)
  deaths      Int      @default(0)
  damageDealt Int      @default(0)
  damageTaken Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Match {
  id        Int      @id @default(autoincrement())
  winnerId  Int
  loserId   Int
  duration  Int
  createdAt DateTime @default(now())
}

model Achievement {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  createdAt DateTime @default(now())
}

model WeaponUsage {
  id         Int      @id @default(autoincrement())
  userId     Int
  weapon     String
  shotsFired Int      @default(0)
  hits       Int      @default(0)
  kills      Int      @default(0)
  damage     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// audit tabel for tracing what is heppening inside the audit
model AuditLog {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  requestId  String?
  actorId    String? // user id or service id
  action     String // e.g. "update_player_stats"
  entityType String // e.g. "Player", "Match"
  entityId   String? // e.g. "player:123"
  before     Json?
  after      Json?
  source     String // "stats_service"
}
